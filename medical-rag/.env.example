LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=medical-rag

# Local LLM via Ollama
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Local embeddings via HuggingFace
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-small-en

# Ingestion / retrieval tuning
INGEST_CHUNK_SIZE=800
INGEST_CHUNK_OVERLAP=120
RETRIEVER_TOP_K=1

# Model tuning
LLM_TEMPERATURE=0
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=128
OLLAMA_REQUEST_TIMEOUT_SECONDS=180
ASK_TIMEOUT_SECONDS=180

# Optional if you switch providers to OpenAI
OPENAI_API_KEY=

DATABASE_URL=postgresql+psycopg2://admin:admin123@localhost:5202/medicalrag
COLLECTION_NAME=medical_docs
DOCUMENTS_DIR=../documents
